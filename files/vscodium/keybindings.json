// Place your key bindings in this file to override the defaults
[
    // I prefer Ctrl+C Ctrl+C for executing notebook cells
    {
        "key": "ctrl+c ctrl+c",
        "command": "notebook.cell.execute",
        "when": "notebookCellListFocused && notebookMissingKernelExtension && !notebookCellExecuting && notebookCellType == 'code' || notebookCellListFocused && !notebookCellExecuting && notebookCellType == 'code' && notebookKernelCount > 0 || notebookCellListFocused && !notebookCellExecuting && notebookCellType == 'code' && notebookKernelSourceCount > 0"
    },
    {
        "key": "meta+enter",
        "command": "-notebook.cell.execute",
        "when": "notebookCellListFocused && notebookMissingKernelExtension && !notebookCellExecuting && notebookCellType == 'code' || notebookCellListFocused && !notebookCellExecuting && notebookCellType == 'code' && notebookKernelCount > 0 || notebookCellListFocused && !notebookCellExecuting && notebookCellType == 'code' && notebookKernelSourceCount > 0"
    },
    {
        "key": "ctrl+c ctrl+c",
        "command": "notebook.cell.quitEdit",
        "when": "inputFocus && notebookEditorFocused && notebookCellType == 'markup'"
    },
    {
        "key": "meta+enter",
        "command": "-notebook.cell.quitEdit",
        "when": "inputFocus && notebookEditorFocused && notebookCellType == 'markup'"
    },
    {
        "key": "ctrl+c ctrl+c",
        "command": "interactive.execute",
        "when": "activeEditor == 'workbench.editor.interactive'"
    },
    {
        "key": "meta+enter",
        "command": "-interactive.execute",
        "when": "activeEditor == 'workbench.editor.interactive'"
    },
    // Explorer keybindings
    {
        "key": "alt+e",
        "command": "workbench.view.explorer",
        "when": "viewContainer.workbench.view.explorer.enabled"
    },
    {
        "key": "alt+e",
        "command": "workbench.action.toggleSidebarVisibility",
        "when": "filesExplorerFocus"
    },
    {
        "key": "g w",
        "command": "workbench.action.files.openFolder",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "c f",
        "command": "workbench.files.action.createFileFromExplorer",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "c d",
        "command": "workbench.files.action.createFolderFromExplorer",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "ctrl+w ctrl+w",
        "command": "workbench.view.explorer",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "ctrl+w l",
        "command": "workbench.view.explorer",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "r",
        "command": "renameFile",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "d",
        "command": "moveFileToTrash",
        "when": "explorerResourceMoveableToTrash && filesExplorerFocus && foldersViewVisible && !explorerResourceReadonly && !inputFocus"
    },
    {
        "key": "ctrl+shift+e",
        "command": "-workbench.view.explorer",
        "when": "viewContainer.workbench.view.explorer.enabled"
    },
    // Terminal keybindings
    {
        "key": "alt+t",
        "command": "workbench.action.togglePanel",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+w ctrl+w",
        "command": "workbench.action.focusPreviousGroup",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+w k",
        "command": "workbench.action.focusPreviousGroup",
        "when": "terminalFocus"
    },
    // Since I want the same bindings in neovim, and CTRL+SHIFT doesn't work in
    // the terminal I switch these to use ALT prefix instead, plus it's just as
    // good anyway
    {
        "key": "alt+g",
        "command": "workbench.view.scm",
        "when": "workbench.scm.active"
    },
    {
        "key": "ctrl+shift+g",
        "command": "-workbench.view.scm",
        "when": "workbench.scm.active"
    },
    {
        "key": "alt+f",
        "command": "workbench.action.findInFiles"
    },
    {
        "key": "ctrl+shift+f",
        "command": "-workbench.action.findInFiles"
    },
    {
        "key": "alt+t",
        "command": "workbench.action.terminal.focus",
        "when": "editorFocus && terminalHasBeenCreated && vim.mode == 'Normal'"
    },
    {
        "key": "alt+t",
        "command": "workbench.action.terminal.new",
        "when": "editorFocus && !terminalHasBeenCreated && vim.mode == 'Normal'"
    },
    {
        "key": "alt+x",
        "command": "workbench.view.extensions",
        "when": "viewContainer.workbench.view.extensions.enabled"
    },
    {
        "key": "ctrl+shift+x",
        "command": "-workbench.view.extensions",
        "when": "viewContainer.workbench.view.extensions.enabled"
    },
    {
        "key": "alt+p",
        "command": "workbench.action.showCommands"
    },
    {
        "key": "ctrl+shift+p",
        "command": "-workbench.action.showCommands"
    },
    // Some vim-based keybindings
    {
        "key": "h",
        "command": "editor.action.scrollLeftHover",
        "when": "editorHoverFocused"
    },
    {
        "key": "j",
        "command": "editor.action.scrollDownHover",
        "when": "editorHoverFocused"
    },
    {
        "key": "k",
        "command": "editor.action.scrollUpHover",
        "when": "editorHoverFocused"
    },
    {
        "key": "l",
        "command": "editor.action.scrollRightHover",
        "when": "editorHoverFocused"
    },
    {
        "key": "q",
        "command": "workbench.action.focusPreviousGroup",
        "when": "editorHoverFocused"
    }
]